{
  "name": "Siren Watch",
  "short_name": "SirenWatch",
  "description": "Listens for emergency siren patterns nearby and alerts you the moment one is detected.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0A0E14",
  "theme_color": "#0A0E14",
