# Public site URL — used for Open Graph / Twitter card absolute URLs.
# Set to your custom domain after configuring DNS in Vercel.
NEXT_PUBLIC_SITE_URL=https://sirenwatch.app

# Optional error monitoring (Sentry browser SDK).
# NEXT_PUBLIC_SENTRY_DSN=

# Web Push — generate keys with:
#   npx web-push generate-vapid-keys
#
# Public key: safe to expose in the browser (must use NEXT_PUBLIC_ prefix).
# Private key: server-only — do NOT commit it.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional: persistent push subscription storage on Vercel (Upstash Redis integration).
# Without these, subscriptions are kept in server memory (fine for local dev only).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
